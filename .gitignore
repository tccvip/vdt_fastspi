# ─────────────────────────────────────────────────────────────────────────────
# Build artifacts
# ─────────────────────────────────────────────────────────────────────────────
build/
out/
_build/
*.o
*.a
*.so
*.so.*
*.d
*.lo

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
install_manifest.txt
Makefile

# Compiled binary
spifast

# ─────────────────────────────────────────────────────────────────────────────
# C / C++
# ─────────────────────────────────────────────────────────────────────────────
*.obj
*.exe
*.pdb
*.ilk
*.exp
*.lib
*.dll

# Address sanitizer / coverage output
*.gcno
*.gcda
*.gcov
default.profraw
*.profdata

# ─────────────────────────────────────────────────────────────────────────────
# DPDK / huge-page runtime files
# ─────────────────────────────────────────────────────────────────────────────
# DPDK creates .rte_ lock files and share maps under /var/run/dpdk at runtime.
# If any of those leak into the working directory, ignore them.
.rte_*
rte_*_pid*

# ─────────────────────────────────────────────────────────────────────────────
# PCAP / test traffic files
# ─────────────────────────────────────────────────────────────────────────────
*.pcap
*.pcapng
*.cap
tests/pcaps/

# ─────────────────────────────────────────────────────────────────────────────
# Log output
# ─────────────────────────────────────────────────────────────────────────────
*.log
logs/

# ─────────────────────────────────────────────────────────────────────────────
# IDE — Visual Studio Code
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ─────────────────────────────────────────────────────────────────────────────
# IDE — JetBrains (CLion)
# ─────────────────────────────────────────────────────────────────────────────
.idea/
cmake-build-*/
*.iml

# ─────────────────────────────────────────────────────────────────────────────
# IDE — Eclipse CDT
# ─────────────────────────────────────────────────────────────────────────────
.cproject
.project
.settings/

# ─────────────────────────────────────────────────────────────────────────────
# IDE — Vim / Emacs
# ─────────────────────────────────────────────────────────────────────────────
*.swp
*.swo
*~
\#*\#
.\#*

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Python (tools/pcap_gen scripts)
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ─────────────────────────────────────────────────────────────────────────────
# Scapy / packet crafting artefacts
# ─────────────────────────────────────────────────────────────────────────────
.scapy_history

